%----------PAGE STYLE----------
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

%----------COLORS----------
\definecolor{primary}{HTML}{1A1A2E}
\definecolor{accent}{HTML}{333333}
\definecolor{lightgray}{HTML}{6B7280}

%----------HYPERLINKS----------
\hypersetup{
    colorlinks=true,
    linkcolor=primary,
    urlcolor=primary,
}

%----------SECTION FORMATTING----------
% Bold small-caps with colored rule
\titleformat{\section}{%
    \vspace{-8pt}\large\bfseries\color{primary}\scshape\raggedright%
}{}{0em}{}[\vspace{-4pt}\color{accent}\rule{\textwidth}{0.8pt}\vspace{-6pt}]

%----------CUSTOM COMMANDS----------

% Education entry: 4 quadrants precisely aligned
% Usage: \eduEntry{School}{Location}{Degree · GPA}{Date}
\newcommand{\eduEntry}[4]{%
    \vspace{5pt}%
    \noindent%
    \begin{tabular*}{\textwidth}{@{}l @{\extracolsep{\fill}} r@{}}
        \textbf{#1} & \textcolor{lightgray}{#2} \\
        \textit{#3} & \textit{\textcolor{lightgray}{#4}} \\
    \end{tabular*}%
    \vspace{-2pt}%
}

% Bullet entry: unified item for Professional Activities, Honors, etc.
% Usage: \bulletEntry{Description}              — no right info
%        \bulletEntry[Location, Year]{Description} — with right info
\newcommand{\bulletEntry}[2][]{%
    \item\small #2%
    \if\relax\detokenize{#1}\relax\else\hfill \textcolor{lightgray}{#1}\fi
}

\endinput
